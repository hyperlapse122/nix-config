{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "@ex-machina/opencode-anthropic-auth@latest",
    "opencode-gemini-auth@latest"
  ],
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.4-mini-fast",
  "autoupdate": "notify",
  "lsp": {
    "buf": {
      "command": [
        "mise",
        "exec",
        "npm:@bufbuild/buf@latest",
        "--",
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [".proto"]
    }
  },
  "permission": {
    "read": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    },
    "edit": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "oauth": {
        "clientId": "NuX7DeFZUot9qo3cGrQngb",
        "clientSecret": "vEdGivHdQVbC0JxMZJDutGRdGea9Ox",
        "redirectUri": "http://127.0.0.1:19876/mcp/oauth/callback",
        "scope": "mcp:connect"
      }
    }
  },
  "provider": {}
}
