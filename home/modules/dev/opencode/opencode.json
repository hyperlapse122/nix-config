{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "@ex-machina/opencode-anthropic-auth@latest",
    "opencode-gemini-auth@latest"
  ],
  "model": "openai/gpt-5.5-fast",
  "small_model": "openai/gpt-5.4-mini-fast",
  "autoupdate": "notify",
  "lsp": {
    "buf": {
      "command": [
        "mise",
        "exec",
        "npm:@bufbuild/buf@latest",
        "--",
        "buf",
        "lsp",
        "serve"
      ],
      "extensions": [".proto"]
    }
  },
  "permission": {
    "read": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    },
    "edit": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    }
  },
  "mcp": {
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "mcp-remote", "http://127.0.0.1:3845/mcp"]
    }
  },
  "provider": {}
}
