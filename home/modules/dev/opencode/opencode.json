{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "@ex-machina/opencode-anthropic-auth@latest",
    "opencode-gemini-auth@latest"
  ],
  "autoupdate": "notify",
  "lsp": {
    "typescript": {
      "command": ["npx", "-y", "typescript-language-server", "--stdio"],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx"
      ],
      "initialization": {
        "preferences": {
          "importModuleSpecifierPreference": "relative"
        }
      }
    },
    "biome": {
      "command": ["npx", "-y", "@biomejs/biome", "lsp-proxy"],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".cts",
        ".ctsx",
        ".cjs",
        ".cjsx",
        ".mts",
        ".mtsx",
        ".mjs",
        ".mjsx",
        ".json",
        ".css",
        ".scss",
        ".html",
        ".vue",
        ".svelte",
        ".json",
        ".yaml",
        ".yml"
      ]
    },
    "buf": {
      "command": ["npx", "-y", "@bufbuild/buf@latest", "lsp", "serve"],
      "extensions": [".proto"]
    }
  },
  "permission": {
    "read": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    },
    "edit": {
      "**/.env*.local": "ask",
      "**/.env*": "allow"
    }
  },
  "mcp": {
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    }
  },
  "provider": {}
}
