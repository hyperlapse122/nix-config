{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/refs/heads/dev/assets/oh-my-opencode.schema.json",
  // Model Mapping Reference: https://github.com/code-yeongyu/oh-my-openagent/blob/dev/src/shared/model-requirements.ts
  "agents": {
    "sisyphus": {
      // Primary
      // "model": "anthropic/claude-opus-4-7",
      // "variant": "max"

      // Fallback (Kimi)
      // "model": "opencode-go/kimi-k2.6"

      // Fallback (OpenAI)
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",
    },
    "hephaestus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",
    },
    "oracle": {
      // Primary
      "model": "openai/gpt-5.5-fast",
      "variant": "high",

      // Fallback
      // "model": "google/gemini-3.1-pro-preview",
      // "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast",
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast",
    },
    "multimodal-looker": {
      // Primary
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",

      // Fallback
      // "model": "opencode-go/minimax-m2.5"
    },
    "prometheus": {
      // Primary
      // "model": "anthropic/claude-opus-4-7",
      // "variant": "max",

      // Fallback
      "model": "openai/gpt-5.5-fast",
      "variant": "high",

      // Common
      "prompt_append": "MANDATORY post-plan workflow (in order, no exceptions): (1) Save plan to `.sisyphus/plans/<name>.md`. (2) Self-review for clarity, verifiability, completeness. (3) ALWAYS invoke Momus for high-accuracy review by passing the plan file path as the sole prompt — NON-NEGOTIABLE, never skip, never mark optional. Address ALL Momus findings before proceeding. (4) Branch: if current branch is not `main` and matches `opencode/*` (auto-generated, dedicated to this task), rename in place via `git branch -m` per project rules or git flow convention (`feature/*`, `bugfix/*`, etc.). Never create parallel branches.",
    },
    "metis": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high",
    },
    "momus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh",
    },
    "atlas": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",

      // Common
      "prompt_append": "MANDATORY post-execution workflow (in order, no exceptions): (1) Update relevant AGENTS.md files with wisdoms learned during execution. (2) BEFORE push: if current branch matches `opencode/*` (auto-generated), rename in place via `git branch -m` per project rules or git flow convention (`feature/*`, `bugfix/*`, etc.) — never create parallel branches. (3) Commit and push all changes. (4) If current branch is not `main`, create or update PR/MR per project conventions with assignee set to the authenticated user. (5) On CI/CD pipeline failure: analyze, fix, push new commits — repeat until pipeline is green. NEVER abandon a failing pipeline.",
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",
    },
  },
  "categories": {
    "visual-engineering": {
      // Primary
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",

      // Fallback
      // "model": "opencode-go/glm-5.1"
    },
    "ultrabrain": {
      // Primary
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh",

      // Fallback
      // "model": "google/gemini-3.1-pro-preview",
      // "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",
    },
    "artistry": {
      // Primary
      // "model": "google/gemini-3.1-pro-preview",
      // "variant": "high"

      // Fallback
      "model": "openai/gpt-5.5-fast",
    },
    "quick": {
      "model": "openai/gpt-5.4-mini-fast",
    },
    "unspecified-low": {
      // Primary
      // "model": "anthropic/claude-sonnet-4-6",

      // Fallback
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
    },
    "unspecified-high": {
      // Primary
      // "model": "anthropic/claude-opus-4-7",
      // "variant": "max",

      // Fallback
      "model": "openai/gpt-5.5-fast",
      "variant": "high",
    },
    "writing": {
      // Primary
      // "model": "google/gemini-3-flash-preview"

      // Fallback
      "model": "openai/gpt-5.5-mini-fast",
    },
  },
  "disabled_mcps": ["playwright"],
  "disabled_skills": ["playwright"],
  "disabled_hooks": [
    "session-notification",
    "no-sisyphus-gpt",
    "comment-checker",
    "claude-code-hooks",
  ],
  "browser_automation_engine": { "provider": "playwright-cli" },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1",
  },
  "notification": { "force_enable": true },
}
